---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineMilestone from '../components/TimelineMilestone.astro';
import { company } from '../data/company';

const pillars = [
  {
    title: 'Work hard, play hard',
    body: 'We do not shy away from hard work, long hours, or tough days. For every difficult day there is an equal and opposite day that makes it all worth it.',
  },
  {
    title: 'Built on vibes',
    body: 'We believe in creating an experience, not just a medium for pushing out great food and drink. Setting the mood and creating a fun atmosphere is paramount.',
  },
  {
    title: 'Relationships first',
    body: 'We strongly believe in forming relationships, whether it be with our guests, with our staff, or with our industry peers. To us, it is of the utmost importance.',
  },
];
---
<BaseLayout
  title="About"
  description="The story behind Grind & Prosper Hospitality — a San Diego restaurant group founded by Pete Cich in 2015."
>
  <section class="page-hero">
    <div class="section-inner">
      <p class="eyebrow">About</p>
      <h1>San Diego hospitality, since {company.founded}.</h1>
    </div>
  </section>

  <section class="story">
    <div class="section-inner story-grid">
      <div class="story-photo" aria-hidden="true">
        <span class="photo-label">Founder photo pending</span>
      </div>
      <div class="story-copy">
        <p class="eyebrow">The founder</p>
        <h2>{company.founderName}</h2>
        <p>{company.whatSection}</p>
      </div>
    </div>
  </section>

  <section class="milestones-section">
    <div class="section-inner">
      <p class="eyebrow">Milestones</p>
      <h2>Where we've been</h2>
      <TimelineMilestone milestones={company.milestones} />
    </div>
  </section>

  <section class="pillars-section">
    <div class="section-inner">
      <p class="eyebrow">Philosophy</p>
      <h2>What we live by</h2>
      <div class="pillars-grid">
        {pillars.map((p) => (
          <div class="pillar">
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="section-inner cta-inner">
      <h2>Meet the people behind it.</h2>
      <a href="/team" class="btn btn-primary">Meet the team</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-block: var(--spacing-section);
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass);
    margin-bottom: 1rem;
  }

  .page-hero {
    background-color: var(--color-brand-paper-dark);
  }

  .page-hero h1 {
    font-size: var(--text-hero);
    line-height: var(--leading-display);
    max-width: 30ch;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .story-photo {
    aspect-ratio: var(--aspect-portrait);
    background: linear-gradient(135deg, var(--color-brand-paper-dark), var(--color-brand-paper));
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
  }

  .photo-label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: rgba(26, 26, 23, 0.4);
  }

  .story-copy h2 {
    font-size: var(--text-section-xl);
    margin-bottom: 1.25rem;
  }

  .story-copy p:not(.eyebrow) {
    font-size: var(--text-lg);
    color: var(--color-brand-ink-light);
    line-height: 1.7;
  }

  .milestones-section {
    background-color: var(--color-brand-paper-dark);
  }

  .milestones-section h2,
  .pillars-section h2 {
    font-size: var(--text-section);
    margin-bottom: 2.5rem;
    max-width: 30ch;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .pillar h3 {
    font-size: var(--text-xl);
    margin-bottom: 0.75rem;
  }

  .pillar p {
    color: var(--color-brand-ink-light);
    line-height: 1.6;
  }

  .cta-band {
    background-color: var(--color-brand-ink);
    color: var(--color-brand-white);
  }

  .cta-inner {
    text-align: center;
    max-width: 30rem;
  }

  .cta-inner h2 {
    font-size: var(--text-section);
    margin-bottom: 1.75rem;
    color: var(--color-brand-white);
  }

  .btn {
    display: inline-block;
    padding: 0.85rem 1.75rem;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-cta);
    text-transform: uppercase;
  }

  .btn-primary {
    background-color: var(--color-brand-white);
    color: var(--color-brand-ink);
  }

  @media (max-width: 60rem) {
    .story-grid {
      grid-template-columns: 1fr;
    }

    .pillars-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
