---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatBand from '../components/StatBand.astro';
import ConceptCard from '../components/ConceptCard.astro';
import { GPH_NETWORK } from '../data/gphNetwork';
import { company } from '../data/company';

// Maps venue name to an image slug where real photography has been
// provided. Venues without an entry here fall back to the placeholder
// gradient card until photography is sent.
const imageSlugs: Record<string, string> = {
  'Coco Maya': 'coco-maya',
  'Louisiana Purchase': 'louisiana-purchase',
  'Coco Cabana': 'cococabana',
};
---
<BaseLayout
  title="Grind & Prosper Hospitality"
  description="A San Diego based restaurant group of six distinct concepts, grinding now to prosper later."
>
  <section class="hero">
    <img src="/images/hero-coco-maya.webp" alt="" class="hero-image" />
    <div class="hero-scrim"></div>
    <div class="hero-inner">
      <p class="eyebrow">San Diego, established {company.founded}</p>
      <h1>Six concepts. <span class="accent-text">One family.</span></h1>
      <p class="hero-copy">{company.whatSection.split('. ').slice(0, 2).join('. ')}.</p>
      <div class="hero-actions">
        <a href="/concepts" class="btn btn-primary">Explore our concepts</a>
        <a href="/about" class="btn btn-secondary">Our story</a>
      </div>
    </div>
  </section>

  <StatBand />

  <section class="concepts-preview">
    <div class="section-inner">
      <div class="section-header">
        <p class="eyebrow">Original concepts</p>
        <h2>Where San Diego comes to drink well</h2>
      </div>
      <div class="concepts-grid">
        {GPH_NETWORK.map((venue, i) => (
          <ConceptCard name={venue.name} url={venue.url} index={i + 1} imageSlug={imageSlugs[venue.name]} />
        ))}
      </div>
    </div>
  </section>

  <section class="careers-band">
    <div class="section-inner careers-inner">
      <h2>We're always growing.</h2>
      <p>Join a team that works hard and plays harder across six San Diego venues.</p>
      <a href="/careers" class="btn btn-primary">See careers</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 34rem;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(26, 26, 23, 0.88) 5%, rgba(26, 26, 23, 0.35) 55%, rgba(26, 26, 23, 0.1) 100%);
  }

  .hero-inner {
    position: relative;
    max-width: 88rem;
    margin-inline: auto;
    padding: 4rem 1.5rem;
    max-width: 42rem;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass-light);
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: var(--text-hero);
    line-height: var(--leading-display);
    color: var(--color-brand-white);
    margin-bottom: 1.5rem;
  }

  .hero h1 .accent-text {
    display: block;
  }

  .hero-copy {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.85);
    margin-bottom: 2rem;
    max-width: 38ch;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.85rem 1.75rem;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-cta);
    text-transform: uppercase;
    transition: all 0.2s var(--ease-smooth);
  }

  .btn-primary {
    background-color: var(--color-brand-white);
    color: var(--color-brand-ink);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background-color: var(--color-brand-brass-light);
  }

  .btn-secondary {
    border: 1px solid var(--color-brand-white);
    color: var(--color-brand-white);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background-color: var(--color-brand-white);
    color: var(--color-brand-ink);
  }

  .section-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-block: var(--spacing-section);
  }

  .section-header {
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .section-header h2 {
    font-size: var(--text-section);
  }

  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .careers-band {
    background-color: var(--color-brand-paper-dark);
  }

  .careers-inner {
    text-align: center;
    max-width: 34rem;
  }

  .careers-inner h2 {
    font-size: var(--text-section);
    margin-bottom: 1rem;
  }

  .careers-inner p {
    color: var(--color-brand-ink-light);
    margin-bottom: 2rem;
  }

  @media (max-width: 60rem) {
    .concepts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .concepts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
