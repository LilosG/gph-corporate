---
import BaseLayout from '../layouts/BaseLayout.astro';
import FullBleedBand from '../components/FullBleedBand.astro';
import StatBand from '../components/StatBand.astro';
import ConceptChapter from '../components/ConceptChapter.astro';
import Interlude from '../components/Interlude.astro';
import { GPH_NETWORK } from '../data/gphNetwork';
import { company } from '../data/company';
import { CHAPTER_IMAGES, INTERLUDE_IMAGES } from '../data/conceptChapters';

const byName = Object.fromEntries(GPH_NETWORK.map((v) => [v.name, v]));

// Deliberate pacing order — not the raw GPH_NETWORK order. Opens and
// closes on the two richest photo sets (Cococabana, Louisiana
// Purchase); the thinnest chapter (Lobby, 2 source photos) sits late,
// bracketed by interludes rather than opening the page on the weakest
// material.
const chapterOrder = [
  'Coco Cabana',
  "Miss B's Coconut Club",
  'Louisiana Purchase',
  'Park 101',
  'Coco Maya',
  'The Lobby Tiki Bar',
];
---
<BaseLayout
  title="Grind & Prosper Hospitality"
  description="A San Diego based restaurant group of six distinct concepts, grinding now to prosper later."
  transparentNav={true}
>
  <FullBleedBand
    src="/images/hero-lp.webp"
    minHeight="var(--min-h-hero)"
    maxWidth="42rem"
    scrim="bottom"
  >
    <p class="eyebrow">San Diego, established {company.founded}</p>
    <h1 class="hero-heading">Six concepts.<br /><span class="accent-text">One family.</span></h1>
    <div class="hero-actions">
      <a href="/concepts" class="btn btn-primary">Explore our concepts</a>
      <a href="/about" class="btn btn-secondary">Our story</a>
    </div>
  </FullBleedBand>

  <StatBand bgImage="/images/cococabana-rooftop-aerial.webp" />

  <FullBleedBand
    src={INTERLUDE_IMAGES[0]}
    minHeight="56vh"
    maxWidth="38rem"
    align="center"
    scrim="solid"
  >
    <h2 class="statement">Six kitchens. Six bars. <span class="accent-text">Zero corporate template.</span></h2>
  </FullBleedBand>

  <ConceptChapter
    name={chapterOrder[0]}
    url={byName[chapterOrder[0]].url}
    index={1}
    hero={CHAPTER_IMAGES[chapterOrder[0]].hero}
    supporting={CHAPTER_IMAGES[chapterOrder[0]].supporting}
  />

  <Interlude src={INTERLUDE_IMAGES[1]} />

  <ConceptChapter
    name={chapterOrder[1]}
    url={byName[chapterOrder[1]].url}
    index={2}
    hero={CHAPTER_IMAGES[chapterOrder[1]].hero}
    supporting={CHAPTER_IMAGES[chapterOrder[1]].supporting}
    reverse={true}
  />

  <ConceptChapter
    name={chapterOrder[2]}
    url={byName[chapterOrder[2]].url}
    index={3}
    hero={CHAPTER_IMAGES[chapterOrder[2]].hero}
    supporting={CHAPTER_IMAGES[chapterOrder[2]].supporting}
  />

  <Interlude src={INTERLUDE_IMAGES[2]} />

  <ConceptChapter
    name={chapterOrder[3]}
    url={byName[chapterOrder[3]].url}
    index={4}
    hero={CHAPTER_IMAGES[chapterOrder[3]].hero}
    supporting={CHAPTER_IMAGES[chapterOrder[3]].supporting}
    reverse={true}
  />

  <ConceptChapter
    name={chapterOrder[4]}
    url={byName[chapterOrder[4]].url}
    index={5}
    hero={CHAPTER_IMAGES[chapterOrder[4]].hero}
    supporting={CHAPTER_IMAGES[chapterOrder[4]].supporting}
  />

  <Interlude src={INTERLUDE_IMAGES[3]} />

  <ConceptChapter
    name={chapterOrder[5]}
    url={byName[chapterOrder[5]].url}
    index={6}
    hero={CHAPTER_IMAGES[chapterOrder[5]].hero}
    supporting={CHAPTER_IMAGES[chapterOrder[5]].supporting}
    reverse={true}
  />

  <section class="culture">
    <div class="culture-inner">
      <p class="eyebrow">Who we are</p>
      <h2>Friends who became <span class="accent-text">family</span>.</h2>
      <p class="culture-body">{company.whoAndWhySection}</p>
      <a href="/team" class="btn btn-outline-ink">Meet the team</a>
    </div>
    <div class="culture-strip">
      {[INTERLUDE_IMAGES[4], INTERLUDE_IMAGES[5], INTERLUDE_IMAGES[6]].map((src) => (
        <div class="culture-tile"><img src={src} alt="" loading="lazy" /></div>
      ))}
    </div>
  </section>

  <FullBleedBand
    src={INTERLUDE_IMAGES[7]}
    minHeight="var(--min-h-panel)"
    maxWidth="34rem"
    align="center"
    scrim="solid"
  >
    <p class="eyebrow">Join the team</p>
    <h2 class="band-heading">We're always growing.</h2>
    <p class="band-body">Join a team that works hard and plays harder across six San Diego venues.</p>
    <a href="/careers" class="btn btn-primary">See careers</a>
  </FullBleedBand>
</BaseLayout>

<style>
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass-light);
    margin-bottom: 1.25rem;
  }

  .hero-heading {
    font-size: var(--text-hero);
    line-height: var(--leading-display);
    color: var(--color-brand-white);
    margin-bottom: 1.75rem;
    max-width: 20ch;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .statement {
    font-size: var(--text-section-xl);
    color: var(--color-brand-white);
    max-width: 20ch;
    margin-inline: auto;
  }

  .band-heading {
    font-size: var(--text-section-xl);
    color: var(--color-brand-white);
    margin-bottom: 1.25rem;
  }

  .band-body {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.9);
    margin-bottom: 2rem;
    max-width: 46ch;
  }

  .full-bleed[data-align='center'] .band-body,
  .full-bleed[data-align='center'] .statement {
    margin-inline: auto;
  }

  .culture {
    background-color: var(--color-brand-paper-dark);
    padding-block: var(--spacing-section-lg);
  }

  .culture-inner {
    max-width: 44rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .culture-inner .eyebrow {
    color: var(--color-brand-brass);
  }

  .culture-inner h2 {
    font-size: var(--text-section);
    margin-bottom: 1.25rem;
  }

  .culture-body {
    font-size: var(--text-editorial);
    color: var(--color-brand-ink-light);
    margin-bottom: 1.75rem;
  }

  .culture-strip {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .culture-tile {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .culture-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 40rem) {
    .hero-heading {
      max-width: 100%;
    }

    .culture-strip {
      grid-template-columns: 1fr;
    }
  }
</style>
