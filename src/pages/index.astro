---
import BaseLayout from '../layouts/BaseLayout.astro';
import FullBleedBand from '../components/FullBleedBand.astro';
import EditorialSplit from '../components/EditorialSplit.astro';
import StatBand from '../components/StatBand.astro';
import ConceptCard from '../components/ConceptCard.astro';
import PhotoMosaic from '../components/PhotoMosaic.astro';
import { GPH_NETWORK } from '../data/gphNetwork';
import { company } from '../data/company';
import { team } from '../data/team';

const imageSlugs: Record<string, string> = {
  'Coco Maya': 'coco-maya',
  'Louisiana Purchase': 'louisiana-purchase',
  'Coco Cabana': 'cococabana',
  "Miss B's Coconut Club": 'miss-bs-coconut-club',
  'Park 101': 'park-101',
  'The Lobby Tiki Bar': 'lobby-tiki-bar',
};

const mosaicImages = GPH_NETWORK.map((venue) => ({
  src: `/images/concept-${imageSlugs[venue.name]}.webp`,
  alt: venue.name,
  name: venue.name,
}));
---
<BaseLayout
  title="Grind & Prosper Hospitality"
  description="A San Diego based restaurant group of six distinct concepts, grinding now to prosper later."
  transparentNav={true}
>
  <FullBleedBand
    src="/images/hero-lp.webp"
    minHeight="var(--min-h-hero)"
    maxWidth="42rem"
    scrim="bottom"
  >
    <p class="eyebrow">San Diego, established {company.founded}</p>
    <h1 class="hero-heading">Six concepts.<br /><span class="accent-text">One family.</span></h1>
    <div class="hero-actions">
      <a href="/concepts" class="btn btn-primary">Explore our concepts</a>
      <a href="/about" class="btn btn-secondary">Our story</a>
    </div>
  </FullBleedBand>

  <StatBand bgImage="/images/cococabana-rooftop-aerial.webp" />

  <EditorialSplit
    eyebrow="How it started"
    body={company.whatSection}
    imageSrc="/images/venue-neon-palm-rooftop.webp"
    imageAlt="Guest enjoying a cocktail beneath a neon palm sign on a rooftop at a Grind & Prosper Hospitality venue"
    imageZoom={1.05}
    ctaLabel="Read our story"
    ctaHref="/about"
  >
    <Fragment slot="heading">Built from one <span class="accent-text">vision</span>.</Fragment>
  </EditorialSplit>

  <FullBleedBand
    src="/images/concept-miss-bs-coconut-club.webp"
    minHeight="var(--min-h-panel)"
    maxWidth="32rem"
    scrim="diagonal"
  >
    <p class="eyebrow">Our philosophy</p>
    <h2 class="band-heading">Built on <span class="accent-text">vibes.</span></h2>
    <p class="band-body">{company.philosophySection}</p>
    <a href="/about" class="btn btn-secondary">Read our story</a>
  </FullBleedBand>

  <PhotoMosaic images={mosaicImages} eyebrow="Six kitchens, six bars, one team" />

  <EditorialSplit
    eyebrow="Who we are"
    body={company.whoAndWhySection}
    imageSrc="/images/concept-park-101.webp"
    imageAlt="Grind & Prosper Hospitality team at one of the six venues"
    ctaLabel="Meet the team"
    ctaHref="/team"
    reverse={true}
  >
    <Fragment slot="heading">Friends who became <span class="accent-text">family</span>.</Fragment>
  </EditorialSplit>

  <section class="concepts-preview">
    <div class="section-inner">
      <div class="section-header">
        <p class="eyebrow">Original concepts</p>
        <h2>Where San Diego comes to drink well</h2>
      </div>
      <div class="concepts-grid">
        {GPH_NETWORK.map((venue, i) => (
          <ConceptCard name={venue.name} url={venue.url} index={i + 1} imageSlug={imageSlugs[venue.name]} />
        ))}
      </div>
    </div>
  </section>

  <section class="leadership-teaser">
    <div class="section-inner">
      <div class="leadership-header">
        <p class="eyebrow">The people behind it</p>
        <h2>Six concepts, one leadership team</h2>
      </div>
      <ul class="leadership-list">
        {team.map((member) => (
          <li class="leadership-chip">
            <span class="member-name">{member.name}</span>
            <span class="member-role">{member.role}</span>
          </li>
        ))}
      </ul>
      <a href="/team" class="btn btn-outline-ink">Meet the full team</a>
    </div>
  </section>

  <FullBleedBand
    src="/images/concept-cococabana.webp"
    minHeight="var(--min-h-panel)"
    maxWidth="34rem"
    align="center"
    scrim="solid"
  >
    <p class="eyebrow">Join the team</p>
    <h2 class="band-heading">We're always growing.</h2>
    <p class="band-body">Join a team that works hard and plays harder across six San Diego venues.</p>
    <a href="/careers" class="btn btn-primary">See careers</a>
  </FullBleedBand>
</BaseLayout>

<style>
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass-light);
    margin-bottom: 1.25rem;
  }

  .hero-heading {
    font-size: var(--text-hero);
    line-height: var(--leading-display);
    color: var(--color-brand-white);
    margin-bottom: 1.75rem;
    max-width: 20ch;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .band-heading {
    font-size: var(--text-section-xl);
    color: var(--color-brand-white);
    margin-bottom: 1.25rem;
  }

  .band-body {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.9);
    margin-bottom: 2rem;
    max-width: 46ch;
  }

  .full-bleed[data-align='center'] .band-body {
    margin-inline: auto;
  }

  .section-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-block: var(--spacing-section);
  }

  .section-header,
  .leadership-header {
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .section-header .eyebrow,
  .leadership-header .eyebrow {
    color: var(--color-brand-brass);
  }

  .section-header h2,
  .leadership-header h2 {
    font-size: var(--text-section);
  }

  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .leadership-teaser {
    background-color: var(--color-brand-paper-dark);
  }

  .leadership-list {
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem 2rem;
  }

  .leadership-chip {
    padding-block: 1.25rem;
    border-top: 1px solid rgba(26, 26, 23, 0.12);
  }

  .member-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-brand-ink);
  }

  .member-role {
    display: block;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-ink-light);
    margin-top: 0.35rem;
  }

  @media (max-width: 60rem) {
    .concepts-grid,
    .leadership-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .concepts-grid,
    .leadership-list {
      grid-template-columns: 1fr;
    }

    .hero-heading {
      max-width: 100%;
    }
  }
</style>
