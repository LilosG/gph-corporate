---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FullBleedBand from '../../components/FullBleedBand.astro';
import ImageStrip from '../../components/ImageStrip.astro';
import { GPH_NETWORK } from '../../data/gphNetwork';
import { VENUE_PAGES } from '../../data/venuePages';

export function getStaticPaths() {
  return VENUE_PAGES.map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

const { venue } = Astro.props;
const network = GPH_NETWORK.find((v) => v.name === venue.name);
const liveUrl = network?.url ?? '#';
---
<BaseLayout
  title={venue.name}
  description={venue.descriptor}
  transparentNav={true}
>
  <FullBleedBand
    src={venue.hero}
    alt={venue.heroAlt}
    minHeight="var(--min-h-hero)"
    maxWidth="40rem"
    scrim="bottom"
  >
    <p class="eyebrow">{venue.neighborhood}</p>
    <h1 class="hero-heading">{venue.name}</h1>
    <p class="hero-descriptor">{venue.descriptor}</p>
    <div class="hero-actions">
      <a href={liveUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Visit {venue.name}
      </a>
      <a href="/concepts" class="btn btn-secondary">All concepts</a>
    </div>
  </FullBleedBand>

  {venue.supporting.length > 0 && (
    <section class="support-section">
      <div class="support-inner">
        <p class="eyebrow">The space</p>
        <ImageStrip images={venue.supporting} alt={`${venue.name} venue photography`} />
      </div>
    </section>
  )}

  <FullBleedBand
    src={venue.hero}
    minHeight="var(--min-h-panel)"
    maxWidth="30rem"
    align="center"
    scrim="solid"
  >
    <p class="eyebrow">Part of the GPH family</p>
    <h2 class="band-heading">See it for yourself.</h2>
    <p class="band-body">
      Menu, hours, reservations, and everything else lives on {venue.name}'s own site.
    </p>
    <a href={liveUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
      Visit {venue.name} &rarr;
    </a>
  </FullBleedBand>
</BaseLayout>

<style>
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass-light);
    margin-bottom: 1.25rem;
  }

  .hero-heading {
    font-size: var(--text-hero);
    line-height: var(--leading-display);
    color: var(--color-brand-white);
    margin-bottom: 1.25rem;
    max-width: 20ch;
  }

  .hero-descriptor {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.9);
    max-width: 46ch;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .support-section {
    background-color: var(--color-brand-paper);
    padding-block: var(--spacing-section);
  }

  .support-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .support-inner .eyebrow {
    color: var(--color-brand-brass);
    padding-inline: 0;
  }

  .band-heading {
    font-size: var(--text-section-xl);
    color: var(--color-brand-white);
    margin-bottom: 1.25rem;
  }

  .band-body {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.9);
    margin-bottom: 2rem;
    max-width: 40ch;
    margin-inline: auto;
  }
</style>
