---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FullBleedBand from '../../components/FullBleedBand.astro';
import ImageStrip from '../../components/ImageStrip.astro';
import VenueInfoBar from '../../components/VenueInfoBar.astro';
import { GPH_NETWORK } from '../../data/gphNetwork';
import { VENUE_PAGES, INTERLUDE_IMAGES } from '../../data/venuePages';

// Closing CTA band backgrounds — offset from the interlude indices already
// used on the home page (0, 3, 6) so a visitor moving from home → venue
// page never sees the same atmosphere shot twice in a row.
const CTA_INTERLUDE_INDEX: Record<string, number> = {
  'the-lobby-tiki-bar': 1,
  'coco-cabana': 2,
  "miss-bs-coconut-club": 4,
  'park-101': 5,
  'coco-maya': 7,
  'louisiana-purchase': 8,
};

export function getStaticPaths() {
  return VENUE_PAGES.map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

const { venue } = Astro.props;
const network = GPH_NETWORK.find((v) => v.name === venue.name);
const liveUrl = network?.url ?? '#';
const ctaImage = INTERLUDE_IMAGES[CTA_INTERLUDE_INDEX[venue.slug] ?? 0];
---
<BaseLayout
  title={venue.name}
  description={venue.descriptor}
  transparentNav={true}
>
  <FullBleedBand
    src={venue.hero}
    alt={venue.heroAlt}
    minHeight="var(--min-h-hero)"
    maxWidth="42rem"
    scrim="bottom"
  >
    <p class="eyebrow">{venue.neighborhood}</p>
    <h1 class="hero-heading">{venue.name}</h1>
    <p class="hero-descriptor">{venue.descriptor}</p>
    <div class="hero-actions">
      <a href={liveUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Visit {venue.name}
      </a>
      <a href="/concepts" class="btn btn-secondary">All concepts</a>
    </div>
  </FullBleedBand>

  <VenueInfoBar neighborhood={venue.neighborhood} address={venue.address} phone={venue.phone} />

  {venue.supporting.length > 0 && (
    <section class="support-section">
      <div class="support-inner">
        <p class="eyebrow">The space</p>
        <h2 class="support-heading">Inside {venue.name}</h2>
        <ImageStrip images={venue.supporting} alt={`${venue.name} venue photography`} />
      </div>
    </section>
  )}

  <FullBleedBand
    src={ctaImage}
    minHeight="var(--min-h-panel)"
    maxWidth="30rem"
    align="center"
    scrim="solid"
  >
    <p class="eyebrow">Part of the GPH family</p>
    <h2 class="band-heading">See it for yourself.</h2>
    <p class="band-body">
      Full menu, hours, and reservations live on {venue.name}'s own site — {venue.address}.
    </p>
    <div class="cta-actions">
      <a href={liveUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Visit {venue.name} &rarr;
      </a>
      <a href="/concepts" class="btn btn-outline-cream">See all six concepts</a>
    </div>
  </FullBleedBand>
</BaseLayout>

<style>
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass-light);
    margin-bottom: 1.25rem;
  }

  .hero-heading {
    font-size: var(--text-hero);
    line-height: var(--leading-display);
    color: var(--color-brand-white);
    margin-bottom: 1.25rem;
    max-width: 20ch;
  }

  .hero-descriptor {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.9);
    max-width: 46ch;
    margin-bottom: 2rem;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-actions {
    justify-content: center;
  }

  .support-section {
    background-color: var(--color-brand-paper);
    padding-block: var(--spacing-section);
  }

  .support-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .support-inner .eyebrow {
    color: var(--color-brand-brass);
    padding-inline: 0;
    margin-bottom: 0.75rem;
  }

  .support-heading {
    font-size: var(--text-section);
    color: var(--color-brand-ink);
    margin-bottom: 2rem;
  }

  .band-heading {
    font-size: var(--text-section-xl);
    color: var(--color-brand-white);
    margin-bottom: 1.25rem;
  }

  .band-body {
    font-size: var(--text-lg);
    color: rgba(247, 243, 234, 0.9);
    margin-bottom: 2rem;
    max-width: 40ch;
    margin-inline: auto;
  }

  .btn-outline-cream {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border: 1px solid rgba(247, 243, 234, 0.4);
    color: var(--color-brand-white);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .btn-outline-cream:hover {
    border-color: var(--color-brand-white);
    background-color: rgba(247, 243, 234, 0.08);
  }
</style>
