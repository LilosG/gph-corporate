---
import { company } from '../data/company';

const stats = [
  { value: String(company.stats.yearsOperating), label: 'Years operating' },
  { value: String(company.stats.venuesCount), label: 'Concepts' },
  { value: String(company.founded), label: 'Founded' },
];
---
<section class="stat-band" aria-label="Company statistics">
  <div class="stat-inner">
    {stats.map((stat) => (
      <div class="stat">
        <p class="value">{stat.value}</p>
        <p class="label">{stat.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .stat-band {
    background-color: var(--color-brand-paper-dark);
    border-block: 1px solid rgba(26, 26, 23, 0.1);
  }

  .stat-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding: 3rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    text-align: center;
  }

  .value {
    font-family: var(--font-mono);
    font-size: var(--text-4xl);
    font-weight: 500;
    color: var(--color-brand-ink);
    margin: 0 0 0.35rem;
  }

  .label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-ink-light);
    margin: 0;
  }

  @media (max-width: 40rem) {
    .stat-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
