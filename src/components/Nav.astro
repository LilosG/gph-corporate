---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Concepts', href: '/concepts' },
  { label: 'Team', href: '/team' },
  { label: 'Careers', href: '/careers' },
  { label: 'Press', href: '/press' },
  { label: 'Contact', href: '/contact' },
];
---
<header class="site-header">
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="wordmark">Grind &amp; Prosper Hospitality</a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true">
      <span></span><span></span><span></span>
    </label>

    <ul class="nav-links">
      {navItems.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-brand-paper);
    border-bottom: 1px solid var(--color-brand-paper-dark);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 88rem;
    margin-inline: auto;
    padding: 1.25rem 1.5rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-brand-ink);
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-ink-light);
    position: relative;
    padding-bottom: 0.35rem;
    transition: color 0.2s var(--ease-smooth);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-brand-brass);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-smooth);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--color-brand-ink);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-toggle-input,
  .nav-toggle-label {
    display: none;
  }

  /* Mobile — pure CSS toggle, no client JS island needed */
  @media (max-width: 47.9375rem) {
    .nav-toggle-label {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle-label span {
      width: 22px;
      height: 2px;
      background-color: var(--color-brand-ink);
      transition: transform 0.2s var(--ease-smooth), opacity 0.2s var(--ease-smooth);
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background-color: var(--color-brand-paper);
      border-bottom: 1px solid var(--color-brand-paper-dark);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s var(--ease-smooth);
    }

    .nav-links li {
      width: 100%;
    }

    .nav-links a {
      display: block;
      padding: 1rem 1.5rem;
    }

    .nav-toggle-input:checked ~ .nav-links {
      max-height: 24rem;
    }
  }
</style>
