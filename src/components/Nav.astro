---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Concepts', href: '/concepts' },
  { label: 'Team', href: '/team' },
  { label: 'Press', href: '/press' },
];
---
<header class="site-header" class:list={[{ transparent }]}>
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="wordmark">
      <img src="/images/gph-logo.png" alt="Grind & Prosper Hospitality" class="logo logo-dark" />
      <img src="/images/gph-logo-white.png" alt="Grind & Prosper Hospitality" class="logo logo-light" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true">
      <span></span><span></span><span></span>
    </label>

    <div class="nav-right">
      <ul class="nav-links">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <div class="nav-ctas">
        <a href="/contact" class="nav-btn nav-btn-outline">Contact</a>
        <a href="/careers" class="nav-btn nav-btn-solid">Careers</a>
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-brand-paper);
    border-bottom: 1px solid var(--color-brand-paper-dark);
  }

  .site-header.transparent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: transparent;
    border-bottom: none;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 88rem;
    margin-inline: auto;
    padding: 1rem 1.5rem;
  }

  .wordmark {
    display: block;
  }

  .logo {
    height: 44px;
    width: auto;
    display: block;
  }

  .logo-dark {
    display: block;
  }

  .logo-light {
    display: none;
  }

  .transparent .logo-dark {
    display: none;
  }

  .transparent .logo-light {
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-ink-light);
    position: relative;
    padding-bottom: 0.35rem;
    transition: color 0.2s var(--ease-smooth);
  }

  .transparent .nav-links a {
    color: rgba(247, 243, 234, 0.85);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-brand-brass);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-smooth);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--color-brand-ink);
  }

  .transparent .nav-links a:hover,
  .transparent .nav-links a:focus-visible {
    color: var(--color-brand-white);
  }

  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-ctas {
    display: flex;
    gap: 0.75rem;
  }

  .nav-btn {
    padding: 0.6rem 1.25rem;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-cta);
    text-transform: uppercase;
    white-space: nowrap;
    transition: all 0.2s var(--ease-smooth);
  }

  .nav-btn-outline {
    border: 1px solid var(--color-brand-ink);
    color: var(--color-brand-ink);
  }

  .transparent .nav-btn-outline {
    border-color: var(--color-brand-white);
    color: var(--color-brand-white);
  }

  .nav-btn-outline:hover,
  .nav-btn-outline:focus-visible {
    background-color: var(--color-brand-ink);
    color: var(--color-brand-white);
  }

  .transparent .nav-btn-outline:hover,
  .transparent .nav-btn-outline:focus-visible {
    background-color: var(--color-brand-white);
    color: var(--color-brand-ink);
  }

  .nav-btn-solid {
    background-color: var(--color-brand-brass);
    color: var(--color-brand-white);
  }

  .nav-btn-solid:hover,
  .nav-btn-solid:focus-visible {
    background-color: var(--color-brand-brass-dark);
  }

  .nav-toggle-input,
  .nav-toggle-label {
    display: none;
  }

  @media (max-width: 60rem) {
    .nav-toggle-label {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle-label span {
      width: 22px;
      height: 2px;
      background-color: var(--color-brand-ink);
    }

    .transparent .nav-toggle-label span {
      background-color: var(--color-brand-white);
    }

    .nav-right {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background-color: var(--color-brand-paper);
      border-bottom: 1px solid var(--color-brand-paper-dark);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s var(--ease-smooth);
    }

    .nav-links {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 0.5rem 0;
    }

    .nav-links a {
      display: block;
      padding: 1rem 1.5rem;
      width: 100%;
      color: var(--color-brand-ink-light);
    }

    .nav-ctas {
      padding: 1rem 1.5rem 1.5rem;
      gap: 0.75rem;
    }

    .nav-btn {
      flex: 1;
      text-align: center;
    }

    .nav-toggle-input:checked ~ .nav-right {
      max-height: 24rem;
    }
  }
</style>
