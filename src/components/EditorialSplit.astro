---
interface Props {
  eyebrow: string;
  body: string;
  imageSrc: string;
  imageAlt?: string;
  imageZoom?: number;
  ctaLabel?: string;
  ctaHref?: string;
  reverse?: boolean;
}
const {
  eyebrow,
  body,
  imageSrc,
  imageAlt = '',
  imageZoom = 1,
  ctaLabel,
  ctaHref,
  reverse = false,
} = Astro.props;
---
<section class="editorial-split" data-reverse={reverse}>
  <div class="split-inner">
    <div class="split-media">
      <img src={imageSrc} alt={imageAlt} loading="lazy" style={`transform: scale(${imageZoom});`} />
    </div>
    <div class="split-copy">
      <p class="eyebrow">{eyebrow}</p>
      <h2><slot name="heading" /></h2>
      <p class="body-copy">{body}</p>
      {ctaLabel && ctaHref && (
        <a href={ctaHref} class="btn btn-outline-ink">{ctaLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .editorial-split {
    background-color: var(--color-brand-paper);
    padding-block: var(--spacing-section);
  }

  .split-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 4rem;
    align-items: center;
  }

  .editorial-split[data-reverse='true'] .split-media {
    order: 2;
  }

  .editorial-split[data-reverse='true'] .split-copy {
    order: 1;
  }

  .split-media {
    aspect-ratio: var(--aspect-portrait);
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .split-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass);
    margin-bottom: 1.25rem;
  }

  .split-copy h2 {
    font-size: var(--text-section);
    margin-bottom: 1.25rem;
  }

  .body-copy {
    font-size: var(--text-editorial);
    color: var(--color-brand-ink-light);
    margin-bottom: 2rem;
    max-width: 42ch;
  }

  @media (max-width: 60rem) {
    .split-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .editorial-split[data-reverse='true'] .split-media,
    .editorial-split[data-reverse='true'] .split-copy {
      order: initial;
    }

    .split-media {
      aspect-ratio: 16 / 10;
    }
  }
</style>
