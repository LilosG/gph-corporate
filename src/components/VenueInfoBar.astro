---
interface Props {
  neighborhood: string;
  address: string;
  phone?: string;
}
const { neighborhood, address, phone } = Astro.props;
const mapsHref = `https://maps.google.com/?q=${encodeURIComponent(address)}`;
const telHref = phone ? `tel:${phone.replace(/[^\d+]/g, '')}` : undefined;
---
<section class="info-band" aria-label="Location and contact">
  <div class="info-inner">
    <div class="info-cell">
      <p class="label">Neighborhood</p>
      <p class="value">{neighborhood}</p>
    </div>
    <div class="info-cell" data-divider="true">
      <p class="label">Address</p>
      <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="value value-link">
        {address}
      </a>
    </div>
    {phone && (
      <div class="info-cell" data-divider="true">
        <p class="label">Phone</p>
        <a href={telHref} class="value value-link">{phone}</a>
      </div>
    )}
  </div>
</section>

<style>
  .info-band {
    background-color: var(--color-brand-paper-dark);
    border-block: 1px solid rgba(26, 26, 23, 0.1);
  }

  .info-inner {
    max-width: 88rem;
    margin-inline: auto;
    padding: 2.5rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    text-align: center;
  }

  .info-cell[data-divider='true'] {
    border-left: 1px solid rgba(26, 26, 23, 0.15);
  }

  .label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-ink-light);
    margin: 0 0 0.5rem;
  }

  .value {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-brand-ink);
    margin: 0;
  }

  .value-link {
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .value-link:hover {
    color: var(--color-brand-brass);
  }

  @media (max-width: 40rem) {
    .info-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .info-cell[data-divider='true'] {
      border-left: none;
      border-top: 1px solid rgba(26, 26, 23, 0.15);
      padding-top: 1.5rem;
    }
  }
</style>
