---
interface Props {
  pageLabel: string;
}
const { pageLabel } = Astro.props;
---
<section class="placeholder-notice">
  <p class="eyebrow">In progress</p>
  <h1>{pageLabel}</h1>
  <p class="note">This page is being actively built. Structure and content are being finalized.</p>
</section>

<style>
  .placeholder-notice {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    max-width: 40rem;
    margin-inline: auto;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-brand-brass);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: var(--text-section);
    margin-bottom: 1rem;
  }

  .note {
    color: var(--color-brand-ink-light);
    font-size: var(--text-lg);
  }
</style>
