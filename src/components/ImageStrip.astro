---
interface Props {
  images: string[];
  alt?: string;
}
const { images, alt = '' } = Astro.props;
---
<section class="image-strip" data-count={images.length}>
  {images.map((src) => (
    <div class="strip-tile">
      <img src={src} alt={alt} loading="lazy" />
    </div>
  ))}
</section>

<style>
  .image-strip {
    display: grid;
    gap: 0.5rem;
    max-width: 88rem;
    margin-inline: auto;
  }

  .image-strip[data-count='1'] {
    grid-template-columns: 1fr;
  }

  .image-strip[data-count='2'] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .image-strip[data-count='3'] {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .strip-tile {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .strip-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-smooth);
  }

  .strip-tile:hover img {
    transform: scale(1.04);
  }

  @media (max-width: 48rem) {
    .image-strip[data-count='3'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 30rem) {
    .image-strip[data-count='2'],
    .image-strip[data-count='3'] {
      grid-template-columns: 1fr;
    }
  }
</style>
