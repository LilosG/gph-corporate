---
interface Props {
  src: string;
  height?: string;
}
const { src, height = '52vh' } = Astro.props;
---
<section class="interlude" style={`--h: ${height};`}>
  <img src={src} alt="" loading="lazy" />
</section>

<style>
  .interlude {
    height: var(--h);
    overflow: hidden;
  }

  .interlude img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
