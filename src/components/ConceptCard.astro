---
interface Props {
  name: string;
  url: string;
  index: number;
  imageSlug?: string;
  image?: string;
  ctaLabel?: string;
}
const { name, url, index, imageSlug, image, ctaLabel = 'Visit site' } = Astro.props;
const resolvedImage = image ?? (imageSlug ? `/images/concept-${imageSlug}.webp` : undefined);
const hasImage = Boolean(resolvedImage);
---
<a href={url} class="concept-card">
  {hasImage ? (
    <img src={resolvedImage} alt={name} loading="lazy" class="card-image" />
  ) : (
    <div class="pending-bg" aria-hidden="true"></div>
  )}
  <div class="card-scrim"></div>
  <span class="index">{String(index).padStart(2, '0')}</span>
  <div class="card-content">
    <h3>{name}</h3>
    {hasImage ? (
      <span class="visit">{ctaLabel} &rarr;</span>
    ) : (
      <span class="visit pending-label">Photography pending</span>
    )}
  </div>
</a>

<style>
  .concept-card {
    position: relative;
    display: block;
    aspect-ratio: var(--aspect-venue);
    overflow: hidden;
  }

  .card-image,
  .pending-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-smooth);
  }

  .pending-bg {
    background: linear-gradient(135deg, var(--color-brand-paper-dark), var(--color-brand-paper));
  }

  .concept-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 15, 13, 0) 45%, rgba(15, 15, 13, 0.85) 100%);
  }

  .index {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(247, 243, 234, 0.75);
    z-index: 1;
  }

  .card-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1.25rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-content h3 {
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-brand-white);
  }

  .visit {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-brass-light);
    white-space: nowrap;
  }

  .pending-label {
    color: var(--color-brand-ink-light);
  }
</style>
