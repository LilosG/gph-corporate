---
interface Props {
  name: string;
  url: string;
  index: number;
  imageSlug?: string;
}
const { name, url, index, imageSlug } = Astro.props;
const hasImage = Boolean(imageSlug);
---
<a href={url} class="concept-card">
  <div class="image-slot" class:list={[{ 'has-image': hasImage }]}>
    {hasImage ? (
      <img src={`/images/concept-${imageSlug}.webp`} alt={name} loading="lazy" />
    ) : (
      <span class="index">{String(index).padStart(2, '0')}</span>
    )}
  </div>
  <div class="card-footer">
    <h3>{name}</h3>
    <span class="visit">Visit site &rarr;</span>
  </div>
</a>

<style>
  .concept-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(26, 26, 23, 0.12);
    transition: border-color 0.2s var(--ease-smooth);
  }

  .concept-card:hover,
  .concept-card:focus-visible {
    border-color: var(--color-brand-brass);
  }

  .image-slot {
    aspect-ratio: var(--aspect-venue);
    background: linear-gradient(135deg, var(--color-brand-paper-dark), var(--color-brand-paper));
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    overflow: hidden;
  }

  .image-slot.has-image {
    padding: 0;
  }

  .image-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-smooth);
  }

  .concept-card:hover .image-slot img {
    transform: scale(1.04);
  }

  .index {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-brand-ink-light);
  }

  .card-footer {
    padding: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-footer h3 {
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .visit {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-brass);
    white-space: nowrap;
  }
</style>
